<odoo>

    <!-- Root Menu -->
    <menuitem id="menu_product_routing_info"
              name="Product Routing Info"
              parent="stock.menu_stock_root"
              sequence="1000"/>

    <!-- ================= STAGE ================= -->
    <record id="view_stage_tree" model="ir.ui.view">
        <field name="name">stage.tree</field>
        <field name="model">stage</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_stage_form" model="ir.ui.view">
        <field name="name">stage.form</field>
        <field name="model">stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

